{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "start",
      "runtimeArgs": [
        "--import",
        "tsx"
      ],
      "args": [
        "${workspaceFolder}/src/index.ts"
      ],
      "outputCapture": "std",
      "internalConsoleOptions": "openOnSessionStart",
      "env": {
        "NODE_ENV": "development"
      },
      "killBehavior": "polite",
    },
    {
      "type": "node",
      "request": "launch",
      "name": "start: readonly",
      "runtimeArgs": [
        "--import",
        "tsx"
      ],
      "args": [
        "${workspaceFolder}/src/index.ts"
      ],
      "outputCapture": "std",
      "internalConsoleOptions": "openOnSessionStart",
      "env": {
        "NODE_ENV": "development",
        "RUN_MODE": "readonly"
      },
      "killBehavior": "polite",
    },
    {
      "type": "node",
      "request": "launch",
      "name": "start: writeonly",
      "runtimeArgs": [
        "--import",
        "tsx"
      ],
      "args": [
        "${workspaceFolder}/src/index.ts"
      ],
      "outputCapture": "std",
      "internalConsoleOptions": "openOnSessionStart",
      "env": {
        "NODE_ENV": "development",
        "RUN_MODE": "writeonly"
      },
      "killBehavior": "polite",
    },
    {
      "type": "node",
      "request": "launch",
      "name": "test: admin",
      "runtimeExecutable": "node",
      "args": [
        "--import",
        "tsx",
        "--test",
        "--test-global-setup=./tests/setup.ts",
        "--test-concurrency=1",
        "${workspaceFolder}/tests/admin/*.test.ts"
      ],
      "outputCapture": "std",
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "test"
      },
    },
    {
      "type": "node",
      "request": "launch",
      "name": "test: api",
      "runtimeExecutable": "node",
      "args": [
        "--import",
        "tsx",
        "--test",
        "--test-global-setup=./tests/setup.ts",
        "--test-concurrency=1",
        "${workspaceFolder}/tests/api/*.test.ts"
      ],
      "outputCapture": "std",
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "test"
      },
    },
    {
      "type": "node",
      "request": "launch",
      "name": "test: stacks-core",
      "runtimeExecutable": "node",
      "args": [
        "--import",
        "tsx",
        "--test",
        "--test-global-setup=./tests/setup.ts",
        "--test-concurrency=1",
        "${workspaceFolder}/tests/stacks-core/*.test.ts",
      ],
      "outputCapture": "std",
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "test"
      },
    },
    {
      "type": "node",
      "request": "launch",
      "name": "test: token-queue",
      "runtimeExecutable": "node",
      "args": [
        "--import",
        "tsx",
        "--test",
        "--test-global-setup=./tests/setup.ts",
        "--test-concurrency=1",
        "${workspaceFolder}/tests/token-queue/*.test.ts"
      ],
      "outputCapture": "std",
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "test"
      },
    },
  ]
}
